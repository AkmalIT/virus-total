generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SubmissionType {
  file
  url
  domain
  hash
}

enum SubmissionStatus {
  accepted
  processing
  completed
  failed
}

enum AnalysisJobType {
  static_analysis
  url_scan
  ai_summary
  sandbox
}

enum AnalysisJobStatus {
  pending
  queued
  running
  completed
  failed
}

enum AnalysisResultType {
  static_report
  sandbox_report
  ai_summary
  reputation
}

enum Severity {
  info
  low
  medium
  high
  critical
}

enum IocType {
  ip
  domain
  url
  hash
  email
}

model User {
  id             String       @id @default(uuid()) @db.Uuid
  email          String       @unique @db.VarChar(320)
  username       String       @unique @db.VarChar(100)
  password_hash  String?      @db.Text
  oauth_provider String?      @db.VarChar(100)
  oauth_subject  String?      @db.VarChar(255)
  role           String       @default("user") @db.VarChar(50)
  created_at     DateTime     @default(now()) @db.Timestamptz(3)
  updated_at     DateTime     @updatedAt @db.Timestamptz(3)
  submissions    Submission[]

  @@index([oauth_provider, oauth_subject])
  @@map("users")
}

model Submission {
  id            String           @id @default(uuid()) @db.Uuid
  user_id       String           @db.Uuid
  user          User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  type          SubmissionType
  status        SubmissionStatus @default(accepted)
  file_name     String?          @db.Text
  mime_type     String?          @db.Text
  size_bytes    BigInt?
  sha256        String?          @db.VarChar(64)
  storage_key   String?          @db.Text
  url           String?          @db.Text
  created_at    DateTime         @default(now()) @db.Timestamptz(3)
  updated_at    DateTime         @updatedAt @db.Timestamptz(3)
  analysis_jobs AnalysisJob[]
  iocs          Ioc[]

  @@unique([type, sha256])
  @@index([user_id])
  @@index([status])
  @@index([created_at(sort: Desc)])
  @@map("submissions")
}

model AnalysisJob {
  id               String            @id @default(uuid()) @db.Uuid
  submission_id    String            @db.Uuid
  submission       Submission        @relation(fields: [submission_id], references: [id], onDelete: Cascade)
  job_type         AnalysisJobType
  status           AnalysisJobStatus @default(pending)
  attempts         Int               @default(0)
  priority         Int               @default(1)
  started_at       DateTime?         @db.Timestamptz(3)
  finished_at      DateTime?         @db.Timestamptz(3)
  error_message    String?           @db.Text
  created_at       DateTime          @default(now()) @db.Timestamptz(3)
  analysis_results AnalysisResult[]

  @@unique([submission_id, job_type])
  @@index([submission_id])
  @@index([status])
  @@index([job_type])
  @@map("analysis_jobs")
}

model AnalysisResult {
  id          String             @id @default(uuid()) @db.Uuid
  job_id      String             @db.Uuid
  job         AnalysisJob        @relation(fields: [job_id], references: [id], onDelete: Cascade)
  severity    Severity
  score       Float?
  result_type AnalysisResultType
  data        Json
  created_at  DateTime           @default(now()) @db.Timestamptz(3)

  @@unique([job_id, result_type])
  @@index([job_id])
  @@index([data], type: Gin)
  @@map("analysis_results")
}

model Ioc {
  id            String     @id @default(uuid()) @db.Uuid
  submission_id String     @db.Uuid
  submission    Submission @relation(fields: [submission_id], references: [id], onDelete: Cascade)
  type          IocType
  value         String     @db.Text
  confidence    Float
  created_at    DateTime   @default(now()) @db.Timestamptz(3)

  @@index([submission_id])
  @@index([type])
  @@index([value])
  @@map("iocs")
}
